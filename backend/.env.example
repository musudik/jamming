# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL="postgresql://jamlyrics:jamlyrics@127.0.0.1:5434/jamlyrics?schema=public"

# Server
PORT=4000

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Default seed admin
SEED_ADMIN_EMAIL="admin@jamlyrics.local"
SEED_ADMIN_PASSWORD="admin123"

# Allowed CORS origin (frontend)
CORS_ORIGIN="http://localhost:5173"
