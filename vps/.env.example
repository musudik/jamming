# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=jamlyrics
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=jamlyrics
# Schema created on first init and used by the app's DATABASE_URL (?schema=...)
POSTGRES_SCHEMA=jamlyrics
# Host port Postgres is published on (the remote app connects here)
POSTGRES_PORT=5432

# ── pgAdmin (web UI to manage Postgres) ────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
PGADMIN_PORT=5050
