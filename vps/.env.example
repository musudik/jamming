# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=jamlyrics
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=jamlyrics
# Schema created on first init and used by the app's DATABASE_URL (?schema=...)
POSTGRES_SCHEMA=jamlyrics
# Host port Postgres is published on (the remote app connects here)
POSTGRES_PORT=5432

# ── pgAdmin (web UI to manage Postgres) ────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
PGADMIN_PORT=5050

# ── Backend API ────────────────────────────────────────────
# Localhost port the backend is published on (host nginx proxies to it).
# Change only if 4000 is already used on your host; then match it in nginx/jamlyrics-api.conf.
BACKEND_PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
SEED_ADMIN_EMAIL=admin@jamlyrics.local
SEED_ADMIN_PASSWORD=change-me-admin-password
# Your Vercel frontend origin (for CORS). No trailing slash.
FRONTEND_ORIGIN=https://jamming-blond.vercel.app

# ── Caddy (HTTPS for the API) ──────────────────────────────
# Public hostname for the API. With sslip.io, embed the VPS IP with dashes:
#   api.<IP-with-dashes>.sslip.io   e.g. api.207-180-235-87.sslip.io
API_DOMAIN=api.207-180-235-87.sslip.io
