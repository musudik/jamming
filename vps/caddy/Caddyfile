# Auto-HTTPS reverse proxy for the JamLyrics API.
# API_DOMAIN comes from .env (e.g. api.207-180-235-87.sslip.io).
#
# Port 80 is used by another service on this VPS, so we don't publish it.
# disable_redirects stops Caddy from needing port 80 for HTTP->HTTPS redirects;
# the cert is obtained via the TLS-ALPN-01 challenge on port 443.
{
	auto_https disable_redirects
}

{$API_DOMAIN} {
	reverse_proxy backend:4000
}
